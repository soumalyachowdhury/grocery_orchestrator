CUSTOMER_LOOKUP_API_URL=http://127.0.0.1:3000/api/customer-id
CUSTOMER_LOOKUP_TIMEOUT_SECONDS=5
STORE_NAME=Fresh Basket Grocery
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
USE_OPENAI_ORCHESTRATOR=true

# Optional GitHub/Codex connector configuration
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_USERNAME=your_github_username
CODEX_API_KEY=your_codex_api_key_here
CODEX_ORG_ID=your_codex_organization_id

# Optional app/connector settings
APP_ENV=development
APP_DEBUG=false
LOG_LEVEL=INFO
CONNECTOR_ENABLED=true
CONNECTOR_SYNC_INTERVAL=3600
API_TIMEOUT=30
OPERATION_TIMEOUT=300
RATE_LIMIT_ENABLED=true
REQUESTS_PER_HOUR=5000
